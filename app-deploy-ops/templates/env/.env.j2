# Docker Compose 环境变量
ENV_NAME={{ env }}
COMPOSE_PROJECT_NAME={{ env }}-middleware

# MySQL
MYSQL_PORT={{ mysql_port | default(3306) }}

# Redis
REDIS_PORT={{ redis_port | default(6379) }}

# Nacos（微服务场景）
NACOS_PORT={{ nacos_port | default(8848) }}

# RabbitMQ
RABBITMQ_PORT={{ rabbitmq_port | default(5672) }}
RABBITMQ_MGMT_PORT={{ rabbitmq_mgmt_port | default(15672) }}