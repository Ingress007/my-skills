spring:
  application:
    name: {{ app_name }}
  profiles:
    active: {{ env }}
  datasource:
    url: jdbc:mysql://{{ db_host }}:{{ db_port }}/{{ db_name }}?useSSL=false&serverTimezone=Asia/Shanghai
    username: {{ mysql.app_user }}
    password: {{ mysql.app_password }}
    driver-class-name: com.mysql.cj.jdbc.Driver
  redis:
    host: {{ redis_host | default('127.0.0.1') }}
    port: {{ redis_port | default(6379) }}
    password: {{ redis.password }}
  {% if nacos_enabled %}
  cloud:
    nacos:
      discovery:
        server-addr: {{ nacos_host }}:{{ nacos_port | default(8848) }}
      config:
        server-addr: {{ nacos_host }}:{{ nacos_port | default(8848) }}
  {% endif %}

server:
  port: {{ app_port }}

logging:
  level:
    root: {{ log_level | default('INFO') }}